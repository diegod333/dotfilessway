{
    "layer": "bottom",
    "position": "top",
    "height": 24,
    "spacing": 0,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["custom/mpris-title", "custom/mpris-prev", "custom/mpris-toggle", "custom/mpris-next"],
    "modules-right": ["pulseaudio", "battery", "clock", "custom/power"],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}"
    },

	"custom/mpris-title": {
        "exec": "playerctl metadata --format '{{ artist }} - {{ title }}' 2>/dev/null || echo ''",
        "interval": 1,
        "max-length": 45,
        "format": "{}",
        "escape": true
    },

    "custom/mpris-prev": {
        "format": " « ",
        "on-click": "playerctl previous"
    },

    "custom/mpris-toggle": {
        "exec": "~/.config/waybar/mpris-toggle.sh",
        "interval": 1,
        "on-click": "playerctl play-pause"
    },

    "custom/mpris-next": {
        "format": " » ",
        "on-click": "playerctl next"
    },

    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTE",
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },
    
    "battery": {
        "bat": "BAT0",
        "adapter": "ADP0",
        "format": "BAT {capacity}%",
        "format-charging": "CHG {capacity}%",
        "format-full": "FULL"
    },

    "clock": {
        "format": "{:%H:%M}",
        "interval": 1
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "~/.config/rofi/scripts/powermenu.sh"
    }
}
